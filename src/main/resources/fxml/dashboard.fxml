<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            prefHeight="700.0"
            prefWidth="1200.0"
            minHeight="500.0"
            minWidth="800.0"
            maxHeight="Infinity"
            maxWidth="Infinity"
            style="-fx-background-color: #4f308c;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.DashboardController">

    <center>
        <VBox alignment="CENTER"
              spacing="40.0"
              maxWidth="Infinity"
              maxHeight="Infinity"
              fillWidth="false">
            <padding>
                <Insets top="50.0" right="60.0" bottom="50.0" left="60.0" />
            </padding>

            <children>
                <Label fx:id="welcomeLabel"
                       text="Welcome!"
                       wrapText="true"
                       textAlignment="CENTER"
                       maxWidth="600.0"
                       style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 20 0;" />

                <VBox alignment="CENTER"
                      spacing="20.0"
                      prefWidth="300.0"
                      maxWidth="380.0"
                      style="-fx-background-color: rgba(0,0,0,0.1); -fx-background-radius: 15; -fx-padding: 30 25 30 25;">
                    <children>
                        <Button fx:id="categoriesButton"
                                text="Categories"
                                onAction="#onCategoriesButtonClick"
                                maxWidth="Infinity"
                                prefHeight="55.0"
                                style="-fx-background-color: black; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;" />

                        <Button fx:id="transactionsButton"
                                text="Transactions"
                                onAction="#onTransactionsButtonClick"
                                maxWidth="Infinity"
                                prefHeight="55.0"
                                style="-fx-background-color: black; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;" />

                        <Button fx:id="reportsButton"
                                text="Reports"
                                onAction="#onReportsButtonClick"
                                maxWidth="Infinity"
                                prefHeight="55.0"
                                style="-fx-background-color: black; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;" />

                        <Button fx:id="logoutButton"
                                text="Logout"
                                onAction="#onLogoutButtonClick"
                                maxWidth="Infinity"
                                prefHeight="55.0"
                                style="-fx-background-color: black; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;" />
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </center>

</BorderPane>