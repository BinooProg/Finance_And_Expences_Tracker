<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="20.0" style="-fx-background-color: #4f308c;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="personal.finance.and.expense.tracker.system.ReportsController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <children>

        <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;" text="Financial Report" />

        <Label fx:id="totalIncomeLabel" style="-fx-font-size: 16; -fx-text-fill: white;" text="Total Income: 0" />

        <Label fx:id="totalExpensesLabel" style="-fx-font-size: 16; -fx-text-fill: white;" text="Total Expenses: 0" />

        <Label fx:id="balanceLabel" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;" text="Balance: 0" />

        <Button fx:id="backButton" onAction="#backBH" prefWidth="120" style="-fx-background-color: black; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="Back" />

    </children>

</VBox>
