<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="800.0"
            style="-fx-background-color: #4f308c;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.CategoriesController">

    <top>
        <Label text="Categories Management"
               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"
               BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets top="20.0" bottom="20.0" />
            </BorderPane.margin>
        </Label>
    </top>

    <left>
        <VBox alignment="TOP_CENTER"
              prefWidth="250.0"
              spacing="15.0"
              style="-fx-background-color: #6a4bb3;">
            <padding>
                <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
            </padding>

            <children>
                <Label text="Category Details"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;" />

                <TextField fx:id="categoryNameField"
                           promptText="Enter category name"
                           style="-fx-background-radius: 10;" />

                <Button fx:id="addEditCategoryButton"
                        text="Add / Edit Category"
                        onAction="#addEditCategoryBH"
                        prefWidth="160.0"
                        style="-fx-background-color: black; -fx-text-fill: white; -fx-background-radius: 20;" />

                <Label fx:id="messageLabel"
                       text="Choose your category"
                       style="-fx-text-fill: white; -fx-font-weight: bold;" />

                <Button fx:id="clearButton"
                        text="Clear"
                        onAction="#clearBH"
                        prefWidth="160.0"
                        style="-fx-background-color: #454443; -fx-text-fill: white; -fx-background-radius: 20;" />

                <Button fx:id="deleteButton"
                        text="Delete"
                        onAction="#onDeleteButtonClick"
                        prefWidth="160.0"
                        style="-fx-background-color: black; -fx-text-fill: white; -fx-background-radius: 20;" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
            </padding>

            <children>
                <TableView fx:id="categoriesTable"
                           prefHeight="350.0"
                           prefWidth="500.0">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="150.0" text="ID" />
                        <TableColumn fx:id="nameColumn" prefWidth="350.0" text="Category Name" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <padding>
                <Insets top="10.0" right="20.0" bottom="20.0" left="20.0" />
            </padding>

            <children>
                <Button fx:id="backButton"
                        text="Back"
                        onAction="#backBH"
                        prefWidth="120.0"
                        style="-fx-background-color: black; -fx-text-fill: white; -fx-background-radius: 20;" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
