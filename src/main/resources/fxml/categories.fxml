<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="800.0"
            stylesheets="@../css/app.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.CategoriesController">

    <top>
        <Label text="Categories Management"
               styleClass="page-title"
               BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets top="20.0" bottom="20.0" />
            </BorderPane.margin>
        </Label>
    </top>

    <left>
        <VBox alignment="TOP_CENTER"
              prefWidth="250.0"
              spacing="15.0"
              styleClass="sidebar-card">
            <padding>
                <Insets top="20.0" right="15.0" bottom="20.0" left="15.0" />
            </padding>

            <children>
                <Label text="Category Details"
                       styleClass="section-title" />

                <TextField fx:id="categoryNameField"
                           promptText="Enter category name"
                           styleClass="field-input" />

                <Button fx:id="addEditCategoryButton"
                        text="Add / Edit Category"
                        onAction="#onAddEditCategoryButtonClick"
                        prefWidth="160.0"
                        styleClass="primary-button compact-button" />

                <Label fx:id="messageLabel"
                       text="Choose your category"
                       styleClass="message-label" />

                <Button fx:id="clearButton"
                        text="Clear"
                        onAction="#onClearButtonClick"
                        prefWidth="160.0"
                        styleClass="secondary-button compact-button" />

                <Button fx:id="deleteButton"
                        text="Delete"
                        onAction="#onDeleteButtonClick"
                        prefWidth="160.0"
                        styleClass="primary-button compact-button" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="10.0" styleClass="content-card">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" prefWidth="500.0">
                    <children>
                        <TextField fx:id="searchCategoryField"
                                   promptText="Search by category name"
                                   styleClass="field-input"
                                   HBox.hgrow="ALWAYS" />

                        <ComboBox fx:id="sortCategoryComboBox"
                                  prefWidth="155.0"
                                  promptText="Sort"
                                  styleClass="field-input" />
                    </children>
                </HBox>

                <TableView fx:id="categoriesTable"
                           prefHeight="350.0"
                           prefWidth="500.0">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
                        <TableColumn fx:id="nameColumn" prefWidth="400.0" text="Category Name" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <padding>
                <Insets top="10.0" right="20.0" bottom="20.0" left="20.0" />
            </padding>

            <children>
                <Button fx:id="backButton"
                        text="Back"
                        onAction="#onBackButtonClick"
                        prefWidth="120.0"
                        styleClass="secondary-button compact-button" />
            </children>
        </HBox>
    </bottom>

</BorderPane>

