<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="483.0" spacing="15.0" style="-fx-background-color: #8677f7;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="personal.finance.and.expense.tracker.system.SignupController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <Label alignment="CENTER" style="-fx-font-weight: bold; -fx-font-size: 18;" styleClass="title" text="Sign Up" />

        <TextField fx:id="firstNameField" promptText="Enter your first name" style="-fx-background-radius: 10;" />
        <TextField fx:id="lastNameField" promptText="Enter your last name" style="-fx-background-radius: 10;" />
        <TextField fx:id="emailField" promptText="Enter your email" style="-fx-background-radius: 10;" />
        <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-background-radius: 10;" />
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" style="-fx-background-radius: 10;" />

        <Button fx:id="signupButton" prefWidth="120.0" style="-fx-background-radius: 20;" text="Sign Up" />

        <HBox alignment="CENTER" spacing="8.0">
            <children>
                <Label text="Already have an account?" />
                <Button fx:id="loginButton" text="Login" />
            </children>
        </HBox>

        <Label fx:id="errorLabel" text="" />
    </children>
</VBox>

