<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #4f308c;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="personal.finance.and.expense.tracker.system.CategoriesController">

    <top>
        <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;" text="Categories Management" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="20.0" top="20.0" />
            </BorderPane.margin>
        </Label>
    </top>

    <left>
        <VBox alignment="TOP_CENTER" prefWidth="250.0" spacing="15.0" style="-fx-background-color: #6a4bb3;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>

            <children>
                <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;" text="Category Details" />

                <TextField fx:id="categoryNameField" promptText="Enter category name" style="-fx-background-radius: 10;" />

                <Button fx:id="addEditCategoryButton" onAction="#addEditCategoryBH" prefWidth="160.0" style="-fx-background-color: black; -fx-text-fill: white; -fx-background-radius: 20;" text="Add / Edit Category" />

                <Button fx:id="clearButton" onAction="#clearBH" prefWidth="160.0" style="-fx-background-color: #454443; -fx-text-fill: white; -fx-background-radius: 20;" text="Clear" />

                <Label fx:id="messageLabel" style="-fx-text-fill: white; -fx-font-weight: bold;" text="" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <children>
                <TableView fx:id="categoriesTable" prefHeight="350.0" prefWidth="500.0">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="150.0" text="ID" />
                        <TableColumn fx:id="nameColumn" prefWidth="350.0" text="Category Name" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
            </padding>

            <children>
                <Button fx:id="backButton" onAction="#backBH" prefWidth="120.0" style="-fx-background-color: black; -fx-text-fill: white; -fx-background-radius: 20;" text="Back" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
