<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="860.0" stylesheets="@../css/app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TransactionsController">

    <top>
        <Label styleClass="compact-page-title" text="Transactions Management" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="12.0" top="12.0" />
            </BorderPane.margin>
        </Label>
    </top>

    <left>
        <VBox alignment="TOP_CENTER" prefWidth="250.0" spacing="12.0" styleClass="sidebar-card">
            <padding>
                <Insets bottom="16.0" left="12.0" right="12.0" top="16.0" />
            </padding>

            <children>
                <Label styleClass="section-title" text="Transaction Details" />

                <TextField fx:id="amountField" promptText="Enter amount" styleClass="field-input" />

                <ComboBox fx:id="categoryComboBox" prefWidth="210.0" promptText="Select category" styleClass="field-input" />

                <ComboBox fx:id="typeComboBox" prefWidth="210.0" promptText="Select type" styleClass="field-input" />

                <HBox alignment="CENTER" spacing="8.0">
                    <children>
                        <DatePicker fx:id="transactionDatePicker" prefWidth="132.0" styleClass="field-input" />
                        <Button fx:id="todayButton" onAction="#onTodayButtonClick" prefHeight="34.0" prefWidth="72.0" styleClass="today-button" text="Today" />
                    </children>
                </HBox>

                <Button fx:id="addEditTransactionButton" onAction="#onAddEditTransactionButtonClick" prefWidth="180.0" styleClass="primary-button compact-button" text="Add / Edit Transaction" />
            <HBox alignment="CENTER" prefHeight="47.0" prefWidth="223.0" spacing="20.0">
               <children>
      
                      <Button fx:id="clearButton" onAction="#onClearButtonClick" prefHeight="43.0" prefWidth="100.0" styleClass="secondary-button compact-button" text="Clear" />
                  <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#onDeleteTransactionButtonClick" prefHeight="43.0" prefWidth="100.0" text="Delete" />
               </children>
            </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="10.0" styleClass="content-card">
            <padding>
                <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" prefWidth="560.0" spacing="10.0">
                    <children>
                        <TextField fx:id="searchTransactionField" promptText="Search by category name or date" styleClass="field-input" HBox.hgrow="ALWAYS" />

                        <ComboBox fx:id="sortTransactionComboBox" prefWidth="155.0" promptText="Sort" styleClass="field-input" />
                    </children>
                </HBox>

                <TableView fx:id="transactionsTable" prefHeight="330.0" prefWidth="560.0">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="52.0" text="ID" />
                        <TableColumn fx:id="categoryNameColumn" prefWidth="160.0" text="Category Name" />
                        <TableColumn fx:id="amountColumn" prefWidth="100.0" text="Amount" />
                        <TableColumn fx:id="typeColumn" prefWidth="95.0" text="Type" />
                        <TableColumn fx:id="dateColumn" prefWidth="170.0" text="Date" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
            </padding>

            <children>
                <Button fx:id="backButton" onAction="#onBackButtonClick" prefWidth="120.0" styleClass="secondary-button compact-button" text="Back" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
