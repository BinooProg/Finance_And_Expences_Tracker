<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="470.0" prefWidth="620.0" styleClass="screen-root" stylesheets="@../css/login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">
    <padding>
        <Insets bottom="20.0" top="20.0" />
    </padding>
    <children>
        <VBox alignment="CENTER" maxWidth="420.0" spacing="18.0" styleClass="login-card">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>
            <children>
                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label styleClass="heading" text="Welcome Back" />
                        <Label styleClass="sub-heading" text="Log in or create a new account" />
                    </children>
                </VBox>

                <VBox spacing="10.0">
                    <children>
                        <Label styleClass="field-label" text="Email" />
                        <TextField fx:id="emailField" promptText="name@example.com" styleClass="field-input" />
                        <Label styleClass="field-label" text="Password" />
                        <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="field-input" />
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="12.0">
                    <children>
                        <Button fx:id="loginButton" onAction="#onLoginButtonClick" prefWidth="160.0" styleClass="primary-button" text="Login" />
                        <Button fx:id="signupButton" onAction="#onSignupButtonClick" prefWidth="160.0" styleClass="secondary-button" text="Sign Up" />
                    </children>
                </HBox>

                <Label fx:id="errorLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="24.0" styleClass="message-label error-text" text="" textAlignment="CENTER">
                    <HBox.margin>
                        <Insets top="2.0" />
                    </HBox.margin>
                </Label>
            </children>
        </VBox>
    </children>
</StackPane>
